{
  "name": "AI DevOps Orchestrator",
  "version": "2.0.0",
  "description": "面向软件开发团队的智能协作平台，通过多个AI Agent模拟完整的软件开发生命周期，从需求分析到代码实现再到自动化部署。",
  "author": "Paraflow",
  "exportDate": "2026-06-06",
  "lastUpdated": "2026-06-06",
  "pages": [
    {
      "id": "dashboard",
      "name": "工作流看板",
      "file": "dashboard.html",
      "route": "/dashboard",
      "type": "primary",
      "description": "实时展示所有开发任务状态的可视化看板页面，按开发阶段分列显示任务卡片"
    },
    {
      "id": "requirements",
      "name": "需求管理",
      "file": "requirements.html",
      "route": "/requirements",
      "type": "primary",
      "description": "需求列表页面，展示所有产品需求的概览信息，支持筛选排序"
    },
    {
      "id": "requirement-detail",
      "name": "需求详情",
      "file": "requirement-detail.html",
      "route": "/requirements/:id",
      "type": "secondary",
      "description": "展示单个需求的完整信息：原始描述、AI生成的需求文档、澄清问答、技术架构方案、任务拆解"
    },
    {
      "id": "architecture-review",
      "name": "架构审核",
      "file": "architecture-review.html",
      "route": "/review/architecture/:id",
      "type": "secondary",
      "description": "技术负责人审核AI架构方案：技术选型、模块设计、接口定义、风险提示、审核操作"
    },
    {
      "id": "code-review",
      "name": "代码审核",
      "file": "code-review.html",
      "route": "/review/code/:id",
      "type": "secondary",
      "description": "三栏布局代码审核：文件树、代码diff视图、AI审查报告（质量评分、问题列表、安全扫描）"
    },
    {
      "id": "deploy-review",
      "name": "部署审核",
      "file": "deploy-review.html",
      "route": "/review/deploy/:id",
      "type": "secondary",
      "description": "部署审核：变更摘要、环境配置、数据库迁移、部署步骤、回滚策略、风险评估"
    },
    {
      "id": "knowledge-base",
      "name": "知识库",
      "file": "knowledge-base.html",
      "route": "/knowledge",
      "type": "primary",
      "description": "知识资产管理：分类导航、AI推荐卡片、高级筛选、引用和质量评分"
    },
    {
      "id": "settings",
      "name": "系统设置",
      "file": "settings.html",
      "route": "/settings",
      "type": "primary",
      "description": "自动化配置：自动化级别、人工审核节点开关、AI行为偏好、超时重试配置"
    },
    {
      "id": "new-requirement",
      "name": "新建需求",
      "file": "new-requirement.html",
      "route": "/requirements/new",
      "type": "secondary",
      "description": "产品经理用自然语言描述需求，AI澄清问答，生成结构化需求文档并提交架构审核"
    },
    {
      "id": "notification-panel",
      "name": "通知中心",
      "file": "notification-panel.html",
      "route": "/notifications",
      "type": "secondary",
      "description": "通知中心：待审核通知、进度通知、系统通知、超时提醒"
    },
    {
      "id": "knowledge-detail",
      "name": "知识条目详情",
      "file": "knowledge-detail.html",
      "route": "/knowledge/:id",
      "type": "deep",
      "description": "知识条目详情：完整内容、核心设计要点、代码示例、质量评分、来源追溯、引用历史"
    },
    {
      "id": "task-detail",
      "name": "任务详情",
      "file": "task-detail.html",
      "route": "/tasks/:id",
      "type": "secondary",
      "description": "单个AI开发任务详情：实时进度、Agent工作日志、代码输出预览、任务依赖、完成标准"
    },
    {
      "id": "deploy-monitoring",
      "name": "部署监控",
      "file": "deploy-monitoring.html",
      "route": "/deploy/monitoring/:id",
      "type": "secondary",
      "description": "部署实时监控：CI/CD流水线进度、健康指标、告警状态、部署历史、回滚按钮"
    },
    {
      "id": "settings-review-rules",
      "name": "审核规则",
      "file": "settings-review-rules.html",
      "route": "/settings/review-rules",
      "type": "settings-sub",
      "description": "审核规则配置：规则列表、触发条件、处理方式、新增规则"
    },
    {
      "id": "settings-dev-environment",
      "name": "开发环境",
      "file": "settings-dev-environment.html",
      "route": "/settings/dev-environment",
      "type": "settings-sub",
      "description": "开发环境连接配置：代码仓库、CI/CD、云服务凭证、SSH密钥、环境变量"
    },
    {
      "id": "settings-model-management",
      "name": "模型管理",
      "file": "settings-model-management.html",
      "route": "/settings/model-management",
      "type": "settings-sub",
      "description": "模型管理：内置模型配置、自定义模型添加（名称/API端点/密钥/能力标签）、连接测试"
    },
    {
      "id": "settings-ai-agent",
      "name": "AI Agent配置",
      "file": "settings-ai-agent.html",
      "route": "/settings/ai-agent",
      "type": "settings-sub",
      "description": "AI Agent配置：Agent卡片、技术偏好、行为参数、信任等级、性能统计"
    },
    {
      "id": "settings-team-members",
      "name": "团队成员",
      "file": "settings-team-members.html",
      "route": "/settings/team-members",
      "type": "settings-sub",
      "description": "团队成员管理：成员列表、角色权限分配、邀请新成员"
    },
    {
      "id": "settings-notifications",
      "name": "通知设置",
      "file": "settings-notifications.html",
      "route": "/settings/notifications",
      "type": "settings-sub",
      "description": "通知配置：通知渠道、事件通知、通知频率、安静时段"
    },
    {
      "id": "settings-integrations",
      "name": "集成配置",
      "file": "settings-integrations.html",
      "route": "/settings/integrations",
      "type": "settings-sub",
      "description": "集成配置：已连接服务、API密钥管理、Webhook配置、同步状态"
    },
    {
      "id": "settings-security",
      "name": "安全与权限",
      "file": "settings-security.html",
      "route": "/settings/security",
      "type": "settings-sub",
      "description": "安全与权限：RBAC角色定义、权限矩阵、数据加密、两步验证、审计日志"
    }
  ],
  "pageTypes": {
    "primary": "一级页面，顶部导航直接访问",
    "secondary": "二级页面，从一级页面进入的流程子页面",
    "deep": "三级页面，从二级页面深入查看的详情页",
    "settings-sub": "设置子页面，从系统设置侧边栏进入的配置页"
  },
